# email-triage configuration
#
# These are read from the environment. The recommended way to set them is via
# phantombot so they live in ~/.env (mode 0600) and are available to both the
# poller and the woken agent turn:
#
#   phantombot env set INBOX_EMAIL        "you@example.com"
#   phantombot env set INBOX_APP_PASSWORD "abcd efgh ijkl mnop"
#
# This file is only a reference of the available variables. Do NOT commit a real
# filled-in copy — it is gitignored as *.env / .env.* for a reason.

# --- Required ---------------------------------------------------------------

# The mailbox this persona watches and triages.
INBOX_EMAIL=you@example.com

# An IMAP *app password* for that mailbox (not your normal login password).
#   - Gmail:    Google Account → Security → App passwords (2FA must be on)
#   - Fastmail: Settings → Privacy & Security → App passwords
#   - Others:   look for "app password" / "app-specific password"
INBOX_APP_PASSWORD=your-imap-app-password

# --- Optional ---------------------------------------------------------------

# IMAP server. Defaults to Gmail. Common values:
#   imap.gmail.com         (Gmail / Google Workspace)
#   imap.fastmail.com      (Fastmail)
#   outlook.office365.com  (Microsoft 365)
INBOX_IMAP_HOST=imap.gmail.com

# IMAP SSL port. Almost always 993.
INBOX_IMAP_PORT=993

# Human-readable label shown in `phantombot task list` for the wake task.
INBOX_TASK_LABEL=Process inbox mail

# Path to a custom triage-prompt template. If unset, the poller uses
# wake-prompt.md next to inbox-poll.py, falling back to a built-in default.
# INBOX_WAKE_PROMPT=/home/you/.local/share/email-triage/wake-prompt.md
