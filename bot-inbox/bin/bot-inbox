#!/usr/bin/env python3
"""
bot-inbox — thin CLI for inter-bot messaging over a shared filesystem inbox.

Two bots on the same host can't talk over Telegram, so they drop JSON
messages into each other's inbox directory on shared storage. The mechanics
are trivial (write + atomic rename); the value of this tool is that the
*message schema and the atomic/dedup/audit rules live in one place* instead
of being re-implemented (slightly differently) by every bot.

Layout (under $BOT_INBOX_ROOT, default /mnt/shared-data/bots/inbox):
    <recipient>/                      pending messages for <recipient>
    <recipient>/<ts>-<from>-<rand>.json
    <recipient>/processed/            audit log of handled messages

Write rule: write to ".<name>.tmp" then rename to "<name>" — atomic on the
same filesystem, so a reader never sees a half-written file. Readers ignore
dotfiles (in-flight writes).

Commands:
    send     drop a message into another bot's inbox
    list     list pending messages in your own inbox
    read     print one pending message (optionally ack it)
    ack      move a handled message to processed/ (the audit log)
    watch    poll your inbox and emit new messages as JSON lines
    roster   list the bots that have an inbox (who you can talk to)
    register create your own inbox so you appear in the roster

Discovery: there's no registry — the directories under the root ARE the
roster. A bot becomes visible the moment it runs any command under its own
name (self-register) or someone sends to it. Use `roster` to see your peers
instead of guessing names.

Identity:
    Your own bot name comes from --from or $PHANTOMBOT_PERSONA, which
    phantombot sets per-turn to the active persona key. Receiving commands
    (list/read/ack/watch) need it to know which inbox is yours.

No secrets in messages — reference env-var names instead.
"""

import argparse
import json
import os
import re
import sys
import time
import uuid
from datetime import datetime, timezone

DEFAULT_ROOT = "/mnt/shared-data/bots/inbox"
# setgid + group-writable, matching install.sh's `chmod 2775` on the root.
# Inboxes are shared between bots that may run under different uids (separate
# LXCs / uid-mappings), so dirs must be group-writable for a peer to drop a
# message. setgid makes files/dirs created inside inherit the inbox group.
INBOX_DIR_MODE = 0o2775
VALID_TYPES = ("request", "response", "notice")
# Required keys in every message payload.
REQUIRED_FIELDS = ("from", "to", "type", "subject", "ts")
NAME_RE = re.compile(r"^[a-z0-9][a-z0-9_-]{0,63}$")


# --------------------------------------------------------------------------- #
# arg parsing helpers
# --------------------------------------------------------------------------- #

class ExampleParser(argparse.ArgumentParser):
    """ArgumentParser that appends a copy-pasteable example to errors.

    A fresh bot that fumbles `send` (forgetting --to/--subject) gets the bare
    argparse "the following arguments are required" plus usage — easy to
    misread. If the subparser carries an `.example`, show it on every error so
    the next attempt can be copied verbatim instead of guessed.
    """

    def error(self, message):
        self.print_usage(sys.stderr)
        example = getattr(self, "example", None)
        if example:
            sys.stderr.write(f"\nexample:\n  {example}\n")
        self.exit(2, f"{self.prog}: error: {message}\n")


# --------------------------------------------------------------------------- #
# helpers
# --------------------------------------------------------------------------- #

def die(msg, code=1):
    print(f"bot-inbox: {msg}", file=sys.stderr)
    sys.exit(code)


def root_dir():
    return os.environ.get("BOT_INBOX_ROOT", DEFAULT_ROOT)


def self_name(args):
    name = getattr(args, "from_", None) or os.environ.get("PHANTOMBOT_PERSONA")
    if not name:
        die("no bot name: pass --from or set $PHANTOMBOT_PERSONA")
    if not NAME_RE.match(name):
        die(f"invalid bot name {name!r}: use [a-z0-9_-], max 64 chars")
    # Self-register: ensure my own inbox dir exists so I show up in `roster`.
    # This is why discovery needs no separate registry — running any command
    # under my own name makes me a visible peer. install.sh can't do this: it
    # has no $PHANTOMBOT_PERSONA, which phantombot only sets per-turn at runtime.
    ensure_registered(name)
    return name


def ensure_registered(name):
    """Best-effort: create my inbox dir so `roster` lists me as a peer.

    Silent on failure — a read-only or missing root shouldn't break a plain
    `list`/`read`. The directory simply won't exist, same as before.
    """
    try:
        ensure_dir(inbox_path(name))
    except OSError:
        pass


def check_name(kind, name):
    if not name or not NAME_RE.match(name):
        die(f"invalid {kind} name {name!r}: use [a-z0-9_-], max 64 chars")
    return name


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def fs_timestamp():
    # Filesystem-safe timestamp with microseconds, so messages sent within the
    # same second still sort in send order. ':' -> '-' for filename safety.
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H-%M-%S-%fZ")


def inbox_path(recipient):
    return os.path.join(root_dir(), recipient)


def ensure_dir(path, mode=INBOX_DIR_MODE):
    """Create an inbox directory group-writable so peer bots can drop messages.

    os.makedirs' `mode` argument is masked by the process umask, and the setgid
    bit is dropped entirely — so a dir created at runtime by a daemon with a
    restrictive umask (e.g. 0077, common under systemd) comes out 0700/root and
    a peer bot running under a *different* uid then can't write to it. That's
    the "folder is owned by root, I can't write" failure. install.sh chmods the
    root explicitly for the same reason; runtime-created subdirs need the same
    treatment, so we chmod after creating to defeat the umask.

    Only chmod dirs we actually create: a pre-existing dir may be owned by
    another bot (our chmod would fail with EPERM) or deliberately tightened by
    an admin — either way it's not ours to re-permission. Best-effort: a failed
    chmod is non-fatal (the makedirs already succeeded).
    """
    created = not os.path.isdir(path)
    os.makedirs(path, exist_ok=True)
    if created:
        try:
            os.chmod(path, mode)
        except OSError:
            pass


def validate_payload(msg):
    """Return a list of human-readable problems (empty == valid)."""
    problems = []
    if not isinstance(msg, dict):
        return ["payload is not a JSON object"]
    for field in REQUIRED_FIELDS:
        if not msg.get(field):
            problems.append(f"missing required field: {field}")
    t = msg.get("type")
    if t and t not in VALID_TYPES:
        problems.append(f"invalid type {t!r}: expected one of {', '.join(VALID_TYPES)}")
    for who in ("from", "to"):
        val = msg.get(who)
        if val and not NAME_RE.match(str(val)):
            problems.append(f"invalid {who} name {val!r}")
    if msg.get("type") == "response" and not msg.get("ref"):
        problems.append("type 'response' should carry a 'ref' correlation-id")
    return problems


def read_body(args):
    # Explicit only — never auto-consume stdin (a bot run under systemd/pipe
    # would block). Use --body, or --body-file (with '-' for stdin).
    if args.body is not None:
        return args.body
    if args.body_file:
        if args.body_file == "-":
            return sys.stdin.read()
        try:
            with open(args.body_file, "r", encoding="utf-8") as fh:
                return fh.read()
        except OSError as e:
            die(f"cannot read body file {args.body_file}: {e}")
    return ""


def list_messages(box):
    """Pending message filenames in <box>, oldest first. Ignores dotfiles."""
    if not os.path.isdir(box):
        return []
    names = [
        n for n in os.listdir(box)
        if n.endswith(".json") and not n.startswith(".")
    ]
    return sorted(names)


def load_message(box, name):
    path = os.path.join(box, name)
    with open(path, "r", encoding="utf-8") as fh:
        return json.load(fh)


# --------------------------------------------------------------------------- #
# commands
# --------------------------------------------------------------------------- #

def cmd_send(args):
    sender = self_name(args)
    recipient = check_name("recipient", args.to)
    if args.type not in VALID_TYPES:
        die(f"invalid --type {args.type!r}: expected one of {', '.join(VALID_TYPES)}")

    ref = args.ref
    # Requests get an auto correlation-id so responses can be matched.
    if not ref and args.type == "request":
        ref = uuid.uuid4().hex[:12]

    msg = {
        "from": sender,
        "to": recipient,
        "type": args.type,
        "subject": args.subject,
        "body": read_body(args),
        "ref": ref,
        "ts": now_iso(),
    }
    if ref is None:
        del msg["ref"]

    problems = validate_payload(msg)
    if problems:
        die("invalid message:\n  - " + "\n  - ".join(problems))

    box = inbox_path(recipient)
    try:
        ensure_dir(box)
    except OSError as e:
        die(f"cannot create inbox {box}: {e}")

    name = f"{fs_timestamp()}-{sender}-{uuid.uuid4().hex[:6]}.json"
    final = os.path.join(box, name)
    tmp = os.path.join(box, "." + name + ".tmp")

    data = json.dumps(msg, ensure_ascii=False, indent=2) + "\n"
    try:
        with open(tmp, "w", encoding="utf-8") as fh:
            fh.write(data)
            fh.flush()
            os.fsync(fh.fileno())
        os.rename(tmp, final)  # atomic on same filesystem
        # fsync the directory so the rename itself survives a host crash,
        # not just the file contents. Best-effort: not every FS supports it.
        try:
            dfd = os.open(box, os.O_DIRECTORY)
            try:
                os.fsync(dfd)
            finally:
                os.close(dfd)
        except (OSError, AttributeError):
            pass
    except OSError as e:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        die(f"cannot deliver message: {e}")

    if args.json:
        print(json.dumps({"id": name, "ref": ref, "to": recipient}, ensure_ascii=False))
    else:
        loc = f" (ref {ref})" if ref else ""
        print(f"sent {args.type} to {recipient}: {name}{loc}")


def cmd_list(args):
    me = self_name(args)
    box = inbox_path(me)
    names = list_messages(box)
    if args.json:
        out = []
        for n in names:
            try:
                m = load_message(box, n)
            except (OSError, json.JSONDecodeError):
                m = {}
            out.append({
                "id": n,
                "from": m.get("from"),
                "type": m.get("type"),
                "subject": m.get("subject"),
                "ref": m.get("ref"),
                "ts": m.get("ts"),
            })
        print(json.dumps(out, ensure_ascii=False, indent=2))
        return
    if not names:
        print(f"no pending messages for {me}")
        return
    print(f"{len(names)} pending for {me}:")
    for n in names:
        try:
            m = load_message(box, n)
            print(f"  {n}")
            print(f"      {m.get('type','?')} from {m.get('from','?')}: "
                  f"{m.get('subject','')}")
        except (OSError, json.JSONDecodeError) as e:
            print(f"  {n}  [unreadable: {e}]")


def _resolve_id(box, names, wanted):
    if wanted is None:
        return names[0] if names else None
    if wanted in names:
        return wanted
    # Allow a unique prefix match for convenience.
    matches = [n for n in names if n.startswith(wanted)]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        die(f"ambiguous id {wanted!r}: matches {len(matches)} messages")
    return None


def cmd_read(args):
    me = self_name(args)
    box = inbox_path(me)
    names = list_messages(box)
    name = _resolve_id(box, names, args.id)
    if not name:
        die("no matching message" if args.id else f"no pending messages for {me}", code=3)

    try:
        msg = load_message(box, name)
    except (OSError, json.JSONDecodeError) as e:
        die(f"cannot read {name}: {e}")

    problems = validate_payload(msg)
    if args.json:
        print(json.dumps({"id": name, "message": msg, "problems": problems},
                         ensure_ascii=False, indent=2))
    else:
        print(f"# {name}")
        for k in ("from", "to", "type", "subject", "ref", "ts"):
            if msg.get(k):
                print(f"{k}: {msg[k]}")
        print()
        print(msg.get("body", ""))
        if problems:
            print("\n[schema warnings]", file=sys.stderr)
            for p in problems:
                print(f"  - {p}", file=sys.stderr)

    if args.ack:
        _do_ack(box, name)


def _do_ack(box, name, fatal=True):
    """Move a handled message to processed/.

    Returns True on success. With fatal=False (used by the watch loop, where
    another consumer may have moved/acked the same message concurrently),
    a failure is logged and False returned instead of exiting — one racing
    ack shouldn't take down a long-running poller.
    """
    processed = os.path.join(box, "processed")
    try:
        ensure_dir(processed)
        os.rename(os.path.join(box, name), os.path.join(processed, name))
    except OSError as e:
        if fatal:
            die(f"cannot ack {name}: {e}")
        print(f"bot-inbox: cannot ack {name}: {e}", file=sys.stderr)
        return False
    print(f"acked -> processed/{name}", file=sys.stderr)
    return True


def cmd_ack(args):
    me = self_name(args)
    box = inbox_path(me)
    names = list_messages(box)
    name = _resolve_id(box, names, args.id)
    if not name:
        die(f"no matching message {args.id!r}", code=3)
    _do_ack(box, name)


def cmd_roster(args):
    """List the bots with an inbox under the root — the peer roster.

    The directories under $BOT_INBOX_ROOT *are* the member list; there's no
    separate registry. A bot appears here the moment it runs any command under
    its own name (self-register) or the moment someone sends to it.
    """
    root = root_dir()
    me = getattr(args, "from_", None) or os.environ.get("PHANTOMBOT_PERSONA")
    if me and NAME_RE.match(me):
        ensure_registered(me)
    if not os.path.isdir(root):
        if args.json:
            print(json.dumps([]))
        else:
            print(f"no inbox root yet: {root}")
        return
    peers = sorted(
        d for d in os.listdir(root)
        if NAME_RE.match(d) and os.path.isdir(os.path.join(root, d))
    )
    if args.json:
        out = [
            {"name": p, "pending": len(list_messages(inbox_path(p))),
             "self": p == me}
            for p in peers
        ]
        print(json.dumps(out, ensure_ascii=False, indent=2))
        return
    if not peers:
        print(f"no bots registered under {root}")
        return
    print(f"{len(peers)} bot(s) under {root}:")
    for p in peers:
        pending = len(list_messages(inbox_path(p)))
        tag = " (you)" if p == me else ""
        load = f"  [{pending} pending]" if pending else ""
        print(f"  {p}{tag}{load}")
    # Bridge discovery → action: show a copy-pasteable send, pointed at a real
    # peer (not self) so the bot doesn't have to reconstruct the flag names.
    example_to = next((p for p in peers if p != me), peers[0])
    print(f'\nsend an intro with:\n  bot-inbox send --to {example_to} '
          '--subject "hi" --body "..."')


def cmd_register(args):
    """Explicitly announce myself by creating my inbox dir.

    Optional: any send/list/read/ack/watch already self-registers. Useful as a
    one-shot onboarding step ("appear in the roster before anyone messages me").
    """
    me = self_name(args)  # self_name() already calls ensure_registered()
    print(f"registered: {inbox_path(me)}")


def cmd_watch(args):
    me = self_name(args)
    box = inbox_path(me)
    ensure_dir(box)
    # On start, suppress what's already pending — unless we're explicitly
    # replaying, or doing a one-shot drain (--once with a primed `seen` set
    # would emit nothing, a silent no-op for the common "drain now" use).
    if args.replay or args.once:
        seen = set()
    else:
        seen = set(list_messages(box))
    interval = max(0.2, args.interval)
    try:
        while True:
            for n in list_messages(box):
                if n in seen:
                    continue
                try:
                    msg = load_message(box, n)
                except json.JSONDecodeError as e:
                    # Genuinely corrupt JSON — mark seen so we report it once,
                    # not on every poll.
                    seen.add(n)
                    print(json.dumps({"id": n, "error": str(e)}), flush=True)
                    continue
                except OSError as e:
                    # Likely transient (e.g. NFS hiccup mid-write). Leave it
                    # unseen so the next poll retries.
                    print(json.dumps({"id": n, "error": str(e)}), flush=True)
                    continue
                seen.add(n)
                print(json.dumps({"id": n, "message": msg}, ensure_ascii=False),
                      flush=True)
                if args.ack:
                    # A racing consumer may have moved it already; don't let
                    # that kill the loop. Drop from `seen` only on a real ack.
                    if _do_ack(box, n, fatal=False):
                        seen.discard(n)
            if args.once:
                return
            time.sleep(interval)
    except KeyboardInterrupt:
        return


# --------------------------------------------------------------------------- #
# arg parsing
# --------------------------------------------------------------------------- #

def build_parser():
    p = ExampleParser(
        prog="bot-inbox",
        description="Thin CLI for inter-bot messaging over a shared inbox.",
    )
    p.add_argument("--from", dest="from_", help="your bot name (default: $PHANTOMBOT_PERSONA)")
    sub = p.add_subparsers(dest="cmd", required=True, parser_class=ExampleParser)

    s = sub.add_parser(
        "send", help="send a message to another bot",
        epilog='example:\n  bot-inbox send --to maeve --subject "hi" '
               '--body "hello, introducing myself"\n'
               '\nDiscover recipient names with `bot-inbox roster` '
               '(don\'t guess).',
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    s.example = ('bot-inbox send --to maeve --subject "hi" '
                 '--body "hello, introducing myself"')
    s.add_argument("--to", required=True, help="recipient bot name")
    s.add_argument("--type", default="request", choices=VALID_TYPES,
                   help="message type (default: request)")
    s.add_argument("--subject", required=True, help="short subject line")
    g = s.add_mutually_exclusive_group()
    g.add_argument("--body", help="message body (else: --body-file or stdin)")
    g.add_argument("--body-file", help="read body from file ('-' for stdin)")
    s.add_argument("--ref", help="correlation-id (auto-generated for requests)")
    s.add_argument("--json", action="store_true", help="machine-readable output")
    s.set_defaults(func=cmd_send)

    s = sub.add_parser("list", help="list pending messages in your inbox")
    s.add_argument("--json", action="store_true", help="machine-readable output")
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("read", help="print one pending message")
    s.add_argument("--id", help="message id or unique prefix (default: oldest)")
    s.add_argument("--ack", action="store_true", help="ack after reading")
    s.add_argument("--json", action="store_true", help="machine-readable output")
    s.set_defaults(func=cmd_read)

    s = sub.add_parser("ack", help="move a handled message to processed/")
    s.add_argument("id", help="message id or unique prefix")
    s.set_defaults(func=cmd_ack)

    s = sub.add_parser("roster", help="list bots that have an inbox (the peer roster)")
    s.add_argument("--json", action="store_true", help="machine-readable output")
    s.set_defaults(func=cmd_roster)

    s = sub.add_parser("register", help="create your own inbox so you appear in the roster")
    s.set_defaults(func=cmd_register)

    s = sub.add_parser("watch", help="poll your inbox, emit new messages as JSON lines")
    s.add_argument("--interval", type=float, default=2.0,
                   help="poll interval seconds (default: 2.0)")
    s.add_argument("--ack", action="store_true",
                   help="ack each message after emitting it")
    s.add_argument("--once", action="store_true",
                   help="scan once and exit (drains pending; implies --replay)")
    s.add_argument("--replay", action="store_true",
                   help="also emit messages already pending at start")
    s.set_defaults(func=cmd_watch)

    return p


def main(argv=None):
    args = build_parser().parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
