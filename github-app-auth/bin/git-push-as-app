#!/usr/bin/env python3
"""
Push commits via GitHub API using the GitHub App identity.
Works around ghs_* tokens not working for git push over HTTPS.
Usage: git-push-as-app [remote] [branch]  (defaults to origin HEAD)
"""

import subprocess
import sys
import os
import json
import base64
import re
import shutil
import urllib.request
import urllib.error


def _real_git():
    """Locate the real git binary, bypassing this project's wrapper.

    Order: $REAL_GIT (exported by the wrapper) → $GITHUB_APP_REAL_GIT →
    /usr/bin/git → PATH search with this script's directory filtered out.
    Without this, plain `git` calls here recurse back into the wrapper
    when the wrapper is earlier in $PATH than the real git.
    """
    for env_var in ("REAL_GIT", "GITHUB_APP_REAL_GIT"):
        candidate = os.environ.get(env_var, "")
        if candidate and os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    if os.path.isfile("/usr/bin/git") and os.access("/usr/bin/git", os.X_OK):
        return "/usr/bin/git"
    self_dir = os.path.dirname(os.path.realpath(__file__))
    saved_path = os.environ.get("PATH", "")
    sanitized = os.pathsep.join(
        d for d in saved_path.split(os.pathsep)
        if d and os.path.realpath(d) != self_dir
    )
    found = shutil.which("git", path=sanitized)
    if found:
        return found
    print("Error: could not locate real git binary (set GITHUB_APP_REAL_GIT)",
          file=sys.stderr)
    sys.exit(1)


GIT = _real_git()


def run(cmd, text=True, **kwargs):
    result = subprocess.run(cmd, capture_output=True, text=text, check=True, **kwargs)
    return result


def api_request(method, url, token, data=None):
    req = urllib.request.Request(url, method=method)
    req.add_header("Authorization", f"Bearer {token}")
    req.add_header("Accept", "application/vnd.github+json")
    if data is not None:
        req.add_header("Content-Type", "application/json")
        body = json.dumps(data).encode("utf-8")
        req.add_header("Content-Length", str(len(body)))
        req.data = body

    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8")
        print(f"API error: {e.code} {e.reason}", file=sys.stderr)
        print(body, file=sys.stderr)
        raise


def get_token():
    env_file = os.path.expanduser("~/.github_env")
    token = os.environ.get("GITHUB_TOKEN", "")
    if not token and os.path.exists(env_file):
        with open(env_file) as f:
            for line in f:
                if line.startswith('export GITHUB_TOKEN='):
                    token = line.split('"', 1)[1].rsplit('"', 1)[0]
                    break
    return token


def main():
    args = sys.argv[1:]

    # Parse flags and positional args
    force = False
    dry_run = False
    remote = None
    branch = None

    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-f", "--force"):
            force = True
        elif a == "--dry-run":
            dry_run = True
        elif a.startswith("-"):
            pass  # ignore unknown flags
        elif remote is None:
            remote = a
        elif branch is None:
            branch = a
        i += 1

    remote = remote or "origin"
    branch = branch or run([GIT, "rev-parse", "--abbrev-ref", "HEAD"]).stdout.strip()

    if dry_run:
        print(f"[dry-run] Would push {branch} to {remote}")
        return

    repo_url = run([GIT, "remote", "get-url", remote]).stdout.strip()

    m = re.search(r'github\.com[/:]([^/]+)/(.+?)(?:\.git)?$', repo_url)
    if not m:
        print(f"Error: could not parse owner/repo from: {repo_url}", file=sys.stderr)
        sys.exit(1)
    owner, repo = m.group(1), m.group(2)

    token = get_token()
    if not token:
        print("Error: GITHUB_TOKEN not set", file=sys.stderr)
        sys.exit(1)

    api_base = f"https://api.github.com/repos/{owner}/{repo}"
    print(f"Pushing {branch} to {owner}/{repo} via GitHub API (App identity)...")

    # Get remote SHA
    remote_sha = ""
    branch_exists_remote = False
    try:
        ref_data = api_request("GET", f"{api_base}/git/refs/heads/{branch}", token)
        remote_sha = ref_data.get("object", {}).get("sha", "")
        branch_exists_remote = bool(remote_sha)
    except urllib.error.HTTPError as e:
        if e.code != 404:
            raise

    # Previous App-pushes upload commits via the API, which recreates commit
    # objects with new SHAs that do NOT exist in the local repo. Detect that
    # so we don't try to use remote_sha as a git ref locally.
    remote_known_locally = False
    if remote_sha:
        try:
            run([GIT, "cat-file", "-e", remote_sha])
            remote_known_locally = True
        except subprocess.CalledProcessError:
            pass

    local_sha = run([GIT, "rev-parse", branch]).stdout.strip()

    if remote_sha == local_sha and remote_sha:
        print("Everything up-to-date")
        return

    is_ancestor = False
    if remote_known_locally:
        try:
            run([GIT, "merge-base", "--is-ancestor", remote_sha, local_sha])
            is_ancestor = True
        except subprocess.CalledProcessError:
            pass

    commits = []
    parent_for_first = ""
    needs_force = False
    # When True, each uploaded commit gets the ORIGINAL commit's parents
    # (translated through sha_map), so merge commits keep both parents.
    # When False, commits are chained linearly via current_parent — that
    # squashes structure and is only correct for the single-commit paths
    # below (force / new branch / divergent rebuild).
    preserve_parents = False

    if force:
        # User asked for force-push: rebuild local HEAD with no parent.
        # NOTE: this squashes ALL history above local_sha into a single
        # rootless commit. Preserving full history under --force would be
        # a useful follow-up but is out of scope here.
        commits = [local_sha]
        parent_for_first = ""
        needs_force = True
    elif is_ancestor:
        # Normal fast-forward: upload only the new commits.
        # --topo-order guarantees parents-before-children, which is what
        # sha_map below relies on. Plain --reverse is date-reverse and
        # can violate topology when commit dates lie.
        rev_list = run([GIT, "rev-list", "--topo-order", "--reverse",
                        f"{remote_sha}..{local_sha}"]).stdout.strip()
        if rev_list:
            commits = rev_list.split("\n")
        parent_for_first = remote_sha
        preserve_parents = True
    elif branch_exists_remote and not remote_known_locally:
        # Remote ref points to a commit we don't have locally — typically
        # because a previous App-push recreated the SHAs via the API. We
        # can't compute a delta against an unknown object, so push local
        # HEAD as a child of the existing remote tip. The ref update is
        # still a fast-forward (parent → child), no force needed.
        # NOTE: any history between the branch-off point and local_sha
        # gets squashed into this one commit. Recovering it would need
        # tree/message matching against the remote via API.
        commits = [local_sha]
        parent_for_first = remote_sha
    elif branch_exists_remote:
        # Truly divergent (remote SHA exists locally but isn't an ancestor).
        # Rebuild HEAD with no parent and force-update the ref.
        commits = [local_sha]
        parent_for_first = ""
        needs_force = True
    else:
        # New branch on the remote.
        # NOTE: only the tip is uploaded — earlier ancestors are lost
        # unless they happen to exist on the remote under matching SHAs.
        commits = [local_sha]
        parent_for_first = ""

    if not commits:
        print("No new commits to push")
        return

    print(f"Pushing {len(commits)} commit(s)...")

    # Cache for trees and blobs already known to exist on the remote
    # to avoid redundant GET/POST calls.
    remote_object_cache = set()

    def upload_tree(tree_sha, api_base, token):
        # 1. Fast path: check if this exact tree SHA is already on GitHub
        if tree_sha in remote_object_cache:
            return tree_sha
        try:
            api_request("GET", f"{api_base}/git/trees/{tree_sha}?recursive=0", token)
            remote_object_cache.add(tree_sha)
            return tree_sha
        except urllib.error.HTTPError as e:
            if e.code != 404:
                raise

        # 2. Not on remote (or we can't see it), must rebuild via API.
        # We use a flat list for ls-tree -r, which the API accepts.
        entries = []
        ls_tree = run([GIT, "ls-tree", "-r", tree_sha]).stdout.strip()
        if not ls_tree:
            # Empty tree
            resp = api_request("POST", f"{api_base}/git/trees", token, {"tree": []})
            return resp["sha"]

        for line in ls_tree.split("\n"):
            # Format: <mode> <type> <sha>\t<path>
            parts = line.split("\t", 1)
            if len(parts) < 2:
                continue
            meta = parts[0].split()
            mode, obj_type, sha, path = meta[0], meta[1], meta[2], parts[1]

            if obj_type == "blob":
                # GitHub returns the existing SHA if content matches, so we don't
                # strictly need a 'blob exists' check, but it's slow to POST.
                # However, there is no simple 'GET blob exists' without downloading.
                content = run([GIT, "cat-file", "-p", sha], text=False).stdout
                encoding = "utf-8"
                try:
                    # Symlinks (mode 120000) contain the target path as text
                    text_content = content.decode("utf-8")
                except UnicodeDecodeError:
                    text_content = base64.b64encode(content).decode("ascii")
                    encoding = "base64"

                blob_resp = api_request("POST", f"{api_base}/git/blobs", token,
                                        {"content": text_content, "encoding": encoding})
                entries.append({
                    "path": path,
                    "mode": mode,
                    "type": "blob",
                    "sha": blob_resp["sha"]
                })
            elif obj_type == "commit":
                # Submodule reference
                entries.append({
                    "path": path,
                    "mode": "160000",
                    "type": "commit",
                    "sha": sha
                })

        tree_data = api_request("POST", f"{api_base}/git/trees", token, {"tree": entries})
        remote_object_cache.add(tree_data["sha"])
        return tree_data["sha"]

    # sha_map: local-original SHA → uploaded-API SHA.
    # Seeded with remote_sha → remote_sha so that the oldest commit(s) in
    # the rev-list — whose parent on the local side IS remote_sha — get
    # the correct parent on the remote side. Merge commits whose second
    # parent points OUTSIDE the rev-list (i.e. an ancestor of remote_sha)
    # fall through to using the original SHA, which exists on the remote
    # unless prior App-pushes have rewritten that part of the history.
    sha_map = {}
    if remote_sha:
        sha_map[remote_sha] = remote_sha

    current_parent = parent_for_first
    for commit_sha in commits:
        tree_sha = run([GIT, "rev-parse", f"{commit_sha}^{{tree}}"]).stdout.strip()
        msg = run([GIT, "log", "-1", "--format=%B", commit_sha]).stdout.strip()
        author_name = run([GIT, "log", "-1", "--format=%an", commit_sha]).stdout.strip()
        author_email = run([GIT, "log", "-1", "--format=%ae", commit_sha]).stdout.strip()
        author_date = run([GIT, "log", "-1", "--format=%aI", commit_sha]).stdout.strip()
        committer_name = run([GIT, "log", "-1", "--format=%cn", commit_sha]).stdout.strip()
        committer_email = run([GIT, "log", "-1", "--format=%ce", commit_sha]).stdout.strip()
        committer_date = run([GIT, "log", "-1", "--format=%cI", commit_sha]).stdout.strip()

        print(f"  Uploading tree for {commit_sha[:7]}...")
        new_tree_sha = upload_tree(tree_sha, api_base, token)

        if preserve_parents:
            orig_parents = run([GIT, "log", "-1", "--format=%P", commit_sha]).stdout.strip().split()
            parents = [sha_map.get(p, p) for p in orig_parents]
        else:
            parents = [current_parent] if current_parent else []

        commit_data = {
            "message": msg,
            "tree": new_tree_sha,
            "parents": parents,
            "author": {"name": author_name, "email": author_email, "date": author_date},
            "committer": {"name": committer_name, "email": committer_email, "date": committer_date},
        }

        commit_resp = api_request("POST", f"{api_base}/git/commits", token, commit_data)
        new_sha = commit_resp["sha"]
        sha_map[commit_sha] = new_sha
        current_parent = new_sha
        print(f"  Created commit {new_sha[:7]}"
              + (f" (parents: {', '.join(p[:7] for p in parents)})" if len(parents) > 1 else ""))

    if branch_exists_remote:
        api_request("PATCH", f"{api_base}/git/refs/heads/{branch}", token,
                    {"sha": current_parent, "force": force or needs_force})
    else:
        api_request("POST", f"{api_base}/git/refs", token,
                    {"ref": f"refs/heads/{branch}", "sha": current_parent})

    print(f"Pushed {branch} → {current_parent[:7]}")


if __name__ == "__main__":
    main()
