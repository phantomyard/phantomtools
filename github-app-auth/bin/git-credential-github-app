#!/usr/bin/env bash
# =============================================================================
# Git credential helper for GitHub App tokens
# Reads token from ~/.github_env (refreshed by systemd timer)
#
# Usage (run once after install):
#   git config --global credential.helper "!$HOME/.local/bin/git-credential-github-app"
# =============================================================================
set -euo pipefail

ENV_FILE="${HOME}/.github_env"
op="${1:-}"

if [[ "$op" != "get" ]]; then
    # For store/erase, we do nothing (token is managed externally)
    exit 0
fi

TOKEN=""

# Read token from env file
if [[ -f "$ENV_FILE" ]]; then
    TOKEN=$(grep '^export GITHUB_TOKEN=' "$ENV_FILE" 2>/dev/null | cut -d'"' -f2 || true)
fi

# Fallback: try environment
if [[ -z "$TOKEN" ]]; then
    TOKEN="${GITHUB_TOKEN:-}"
fi

if [[ -n "$TOKEN" ]]; then
    echo "username=x-access-token"
    echo "password=$TOKEN"
fi
