# ─── Voice Agent Configuration ──────────────────────────────────────
# Copy to `.env` and fill in. Required vars marked [REQUIRED].

# Public hostname this server is reachable at (must match TLS cert and
# Twilio webhook URLs). Used to build TwiML and WebSocket URLs.
SERVER_DOMAIN=voice.example.com                  # [REQUIRED]
PORT=8080

# ─── Identity ───────────────────────────────────────────────────────
# Names shown in spoken greetings, system prompt, and transcripts.
PRINCIPAL_NAME=Your Name                         # the person the agent represents
ASSISTANT_NAME=Voice Assistant                   # what the agent calls itself

# Optionally override the entire system prompt. ${ASSISTANT_NAME} and
# ${PRINCIPAL_NAME} are interpolated at startup. Leave empty to use the
# built-in default.
# VOICE_SYSTEM_PROMPT=

# Optional welcome line for inbound calls. Defaults to a generic
# "Hello! This is ${ASSISTANT_NAME}. How can I help you today?"
# WELCOME_INBOUND=

# ─── Memory injection (optional) ────────────────────────────────────
# When set, the agent injects MEMORY.md and the daily notes from
# `${MEMORY_WORKSPACE}/memory/YYYY-MM-DD.md` into the system prompt
# (today + yesterday). Leave empty to disable context loading.
# MEMORY_WORKSPACE=/home/you/clawd
# MEMORY_TIMEZONE=Europe/Amsterdam                # IANA tz, defaults to UTC

# ─── Twilio ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # [REQUIRED for outbound]
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx       # [REQUIRED — also gates inbound webhook signature]
TWILIO_PHONE_US=+14155550100                     # caller-ID for non-NL recipients
TWILIO_PHONE_NL=+31970000000                     # caller-ID for +31 recipients

# ─── Caller whitelist ───────────────────────────────────────────────
# Comma-separated. Calls from numbers/SIP users not in these lists are
# rejected at the TwiML layer with a polite Hangup.
ALLOWED_CALLERS=+15551234567,+447700900123
ALLOWED_SIP_USERS=alice
# AGENT_NUMBERS — your own dialable numbers (SIP calls TO these connect
# to the voice agent; SIP calls TO others get bridged out via PSTN).
# If unset, derives from TWILIO_PHONE_US + TWILIO_PHONE_NL.
# AGENT_NUMBERS=+15551234567,+31970000000

# ─── LLM (OpenRouter, OpenAI-compatible) ────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # [REQUIRED]
# Primary model (low-latency speech LLM recommended)
# VOICE_AGENT_MODEL=inception/mercury-2
# Fallback when primary returns 5xx/provider_unavailable. Set to "" to disable.
# VOICE_AGENT_FALLBACK_MODEL=anthropic/claude-haiku-4.5

# ─── /initiate-call bearer token ────────────────────────────────────
# Generate with: openssl rand -hex 32
# If unset, the endpoint is open — never deploy without it.
VOICE_AGENT_API_TOKEN=                           # [REQUIRED for production]

# ─── Optional assistant relay (phantombot) ──────────────────────────
# When `phantombot` is on PATH, the LLM gets an `ask_assistant` tool
# that shells out to it for queries the inline LLM can't answer
# (older history, web search, home automation, etc.). Without it, the
# tool is still exposed but every call returns an error.
# PHANTOMBOT_BIN=phantombot
# PHANTOMBOT_STREAM_BIN=phantombot-stream
# PHANTOMBOT_ASK_TIMEOUT_MS=60000

# Streaming variant: pipe phantombot stdout straight to ConversationRelay
# tokens, skipping the second LLM round-trip. Set to "1" to enable.
# VOICE_AGENT_STREAM_ASK=0
